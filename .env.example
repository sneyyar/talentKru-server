# =============================================================================
# TalentKru.ai Server — Environment Variables
# Copy this file to .env and fill in all required values before starting.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=talentkru
DATABASE_USER=talentkru
DATABASE_PASSWORD=change_me_required

# -----------------------------------------------------------------------------
# Security (required — must not be empty)
# JWT_SIGNING_KEY  : HMAC-SHA256 secret used exclusively for signing JWTs.
# ENCRYPTION_KEY   : Secret used exclusively for field-level PII encryption.
#                    Keep these two keys separate; they serve distinct purposes.
# -----------------------------------------------------------------------------
JWT_SIGNING_KEY=change_me_required_min_32_chars_long
ENCRYPTION_KEY=change_me_required_min_32_chars_long

# -----------------------------------------------------------------------------
# Storage backend (required)
# STORAGE_BACKEND  : "local" stores resumes on the filesystem;
#                    "s3" stores resumes in an S3-compatible bucket.
# STORAGE_LOCAL_PATH: Filesystem directory used when STORAGE_BACKEND=local.
# RESUME_BUCKET_NAME: S3 bucket name used when STORAGE_BACKEND=s3.
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/resumes
RESUME_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Agent security (required — must not be empty)
# All requests to /internal/agents/* must include this key in X-Agent-API-Key.
# -----------------------------------------------------------------------------
AGENT_API_KEY=change_me_required

# -----------------------------------------------------------------------------
# Metrics endpoint authentication (required — must not be empty)
# Prometheus scrape endpoint at GET /metrics uses HTTP Basic Auth.
# -----------------------------------------------------------------------------
METRICS_USERNAME=metrics
METRICS_PASSWORD=change_me_required

# -----------------------------------------------------------------------------
# Portal settings (optional — defaults shown)
# PORTAL_TOKEN_TTL_DAYS: Lifetime in days for candidate portal access tokens.
# -----------------------------------------------------------------------------
PORTAL_TOKEN_TTL_DAYS=7

# -----------------------------------------------------------------------------
# AI model identifiers (optional — defaults shown)
# These values are passed to the AI provider SDK as model identifiers.
# -----------------------------------------------------------------------------
AI_RESUME_MODEL=gemini-1.5-pro
AI_MATCHING_MODEL=gemini-1.5-pro
AI_FEEDBACK_MODEL=gemini-1.5-pro

# -----------------------------------------------------------------------------
# Reporting (optional — defaults shown)
# INTERVIEW_LEADERBOARD_DEFAULT_PERIOD_DAYS: Rolling window for leaderboard.
# -----------------------------------------------------------------------------
INTERVIEW_LEADERBOARD_DEFAULT_PERIOD_DAYS=30

# -----------------------------------------------------------------------------
# Application metadata (optional)
# APP_VERSION: Semantic version string returned by GET /health.
# -----------------------------------------------------------------------------
APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Test database (used with the "test" Docker Compose profile only)
# -----------------------------------------------------------------------------
TEST_DATABASE_HOST=localhost
TEST_DATABASE_PORT=5433
TEST_DATABASE_NAME=talentkru_test
TEST_DATABASE_USER=talentkru_test
TEST_DATABASE_PASSWORD=talentkru_test_secret
